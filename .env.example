# Required: Gemini API key for diagnosis
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: protect /api/research/export endpoint (query token)
# Leave empty to disable token check in development.
KAGAMI_EXPORT_TOKEN=your_random_export_token_here

# Note: NODE_ENV is managed by Next.js automatically.
# - npm run dev => development
# - npm run build && npm start => production
