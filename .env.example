# Required: Gemini API key for diagnosis
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: protect /api/research/export endpoint (query token)
# Leave empty to disable token check in development.
KAGAMI_EXPORT_TOKEN=your_random_export_token_here

# Note: NODE_ENV is managed by Next.js automatically.
# - npm run dev => development
# - npm run build && npm start => production

# Optional: Global fallback model if frontend provides nothing. 
# Defaults to Gemini if empty. To dynamically shift all users to a specific model 
# in production for telemetry routing, set this (e.g., 'gpt-4o').
# MAGIC SETTING: Set to 'random' to automatically randomly pick one model from the whitelist per request!
# You can also use 'random-gemini' or 'random-github' to randomly select from a specific provider's whitelist.
ACTIVE_DIAGNOSTIC_MODEL=

# Optional: Gemini models comma-separated whitelist and blacklist
GEMINI_MODELS_WHITELIST=gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-1.5-pro,gemini-1.5-flash
GEMINI_MODELS_BLACKLIST=

# Required to use GitHub Models for multi-model research
# Get your token from GitHub (Personal Access Token required / Copilot token)
GITHUB_TOKEN=

# Optional: GitHub models comma-separated whitelist and blacklist
GITHUB_MODELS_WHITELIST=gpt-4o,gpt-4o-mini,meta-llama-3-70b-instruct,mistral-large
GITHUB_MODELS_BLACKLIST=
